DASHSCOPE_API_KEY=your_dashscope_api_key
DEEPSEEK_API_KEY=your_deepseek_api_key
SENSE_API_KEY=your_sensenova_api_key
STEAM_API_KEY=your_steam_api_key
FIRECRAWL_API_KEY=your_firecrawl_api_key

# LLM 默认 Provider（用于报告生成，可选: qwen / deepseek / sense / local）
LLM_PROVIDER=sense

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autoflux

# Optional
OPENAI_API_KEY=

# ── YouTube Data API ────────────────────────────────
YOUTUBE_API_KEY_1=
YOUTUBE_API_KEY_2=
